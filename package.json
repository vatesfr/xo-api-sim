{
  "name": "xo-api-mock",
  "version": "0.1.0",
  "description": "Mock server for Xen Orchestra API",
  "main": "dist/index.js",
  "scripts": {
    "start": "ts-node src/index.ts",
    "build": "tsc",
    "prepare": "npm run build",
    "lint": "eslint src/",
    "format": "prettier --ignore-unknown --write src/",
    "check": "eslint src/"
  },
  "lint-staged": {
    "*": [
      "prettier --ignore-unknown --write"
    ],
    "*.{{ts,mts,cts,js,mjs,cjs}}": [
      "eslint --fix"
    ]
  },
  "dependencies": {
    "@types/express": "^4.17.17",
    "@vates/types": "^1.26.0",
    "complex-matcher": "^1.1.1",
    "express": "^4.18.2",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.1",
    "typescript": "^5.0.4",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/uuid": "^10.0.0",
    "eslint": "^10.5.0",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "typescript-eslint": "^8.61.1"
  }
}
